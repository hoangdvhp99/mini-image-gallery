<%- include('partials/head', { title: 'Beo Caro LAN Online - BeoHub Minigame' }) %>
<body class="min-h-screen font-outfit text-gray-300">
    <div class="w-full px-4 md:px-8 py-4">
        <%- include('partials/nav', { isMinigame: true }) %>

        <!-- MINIGAME CONTENT -->
        <section id="minigameSection" class="transition-all duration-300 max-w-[1440px] mx-auto pt-4">
            <div id="minigameContainer" class="w-full space-y-6 transition-all duration-500">
                
                <!-- Khu Vực Bàn Chơi Beo Caro LAN Online -->
                <div id="caroPlayground" class="bg-neutral-900 border border-neutral-800 rounded-3xl p-4 md:p-6 shadow-2xl flex flex-col gap-6 relative overflow-hidden select-none w-full">
                    
                    <!-- 1. MÀN HÌNH SẢNH CHỜ (LOBBY SCREEN) -->
                    <div id="caroLobbyPanel" class="space-y-6">
                        <div class="text-center space-y-2">
                            <span class="text-5xl block animate-bounce">⚔️👑</span>
                            <h3 class="text-xl font-black text-cyan-400 uppercase tracking-widest">SẢNH CHỜ CARO LAN ONLINE</h3>
                            <p class="text-xs text-neutral-400 max-w-md mx-auto leading-relaxed">
                                Tạo phòng mới hoặc nhập mã PIN của bạn chơi để bắt đầu màn so tài cân não!
                            </p>
                        </div>

                        <!-- Nhập tên chung -->
                        <div class="max-w-md mx-auto bg-neutral-950 p-4 rounded-2xl border border-neutral-850">
                            <label for="caroPlayerNameInput" class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1.5 pl-1">
                                TÊN KỲ THỦ (Tối đa 15 ký tự)
                            </label>
                            <input type="text" id="caroPlayerNameInput" maxlength="15" autocomplete="off" placeholder="Ví dụ: KỳThủCaro..." 
                                   class="w-full bg-neutral-900 border border-neutral-800 focus:border-cyan-500/50 rounded-xl px-4 py-3 text-sm text-white font-bold outline-none transition shadow-inner">
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                            <!-- Cột Trái: Tạo Phòng -->
                            <div class="bg-neutral-950 p-6 rounded-2xl border border-neutral-850 space-y-4 flex flex-col justify-between shadow-inner">
                                <div class="space-y-3">
                                    <h4 class="text-sm font-black text-emerald-400 uppercase tracking-wider border-b border-neutral-850 pb-2 flex items-center gap-1.5">
                                        <span>🔑</span> TẠO PHÒNG MỚI
                                    </h4>
                                    <p class="text-[11px] text-gray-500 leading-relaxed">
                                        Trở thành chủ phòng và mời bạn chơi tham gia thông qua mã PIN 4 chữ số ngẫu nhiên.
                                    </p>
                                    
                                    <!-- Cấu hình thời gian suy nghĩ -->
                                    <div class="space-y-2 pt-2">
                                        <label for="caroCreateTimerSelect" class="block text-[10px] font-black text-gray-500 uppercase tracking-widest pl-1">
                                            Thời gian mỗi lượt đi
                                        </label>
                                        <select id="caroCreateTimerSelect" class="w-full bg-neutral-900 text-cyan-400 font-bold border border-neutral-800 rounded-xl px-3 py-2 text-xs outline-none cursor-pointer">
                                            <option value="10">⚡ Chớp Nhoáng (10 giây)</option>
                                            <option value="30" selected>⏱️ Mặc Định (30 giây)</option>
                                            <option value="60">🧠 Suy Ngẫm (60 giây)</option>
                                            <option value="120">🐢 Kỳ Thủ (120 giây)</option>
                                            <option value="custom">⚙️ Tự Điền Giây...</option>
                                        </select>
                                        
                                        <!-- Custom seconds input (hidden by default) -->
                                        <div id="caroCreateTimerCustomBox" class="hidden animate-slide-in mt-2">
                                            <input type="number" id="caroCreateTimerCustomInput" min="5" max="300" placeholder="Nhập số giây (5s - 300s)..." 
                                                   class="w-full bg-neutral-900 border border-neutral-800 focus:border-cyan-500/50 rounded-xl px-3 py-2.5 text-xs text-white font-bold outline-none transition">
                                        </div>
                                    </div>
                                </div>
                                <button id="btnCaroCreateRoom" class="w-full bg-emerald-500 hover:bg-emerald-400 text-black py-3 rounded-xl font-black text-xs tracking-wider transition duration-150 shadow-lg shadow-emerald-500/10 mt-4">
                                    TẠO PHÒNG CHƠI 🚀
                                </button>
                            </div>

                            <!-- Cột Phải: Vào Phòng -->
                            <div class="bg-neutral-950 p-6 rounded-2xl border border-neutral-850 space-y-4 flex flex-col justify-between shadow-inner">
                                <div class="space-y-3">
                                    <h4 class="text-sm font-black text-cyan-400 uppercase tracking-wider border-b border-neutral-850 pb-2 flex items-center gap-1.5">
                                        <span>⚔️</span> VÀO PHÒNG SẴN CÓ
                                    </h4>
                                    <p class="text-[11px] text-gray-500 leading-relaxed">
                                        Nhập mã PIN 4 chữ số được chia sẻ bởi bạn chơi của bạn để bắt đầu trận đấu trực tiếp.
                                    </p>
                                    <div class="space-y-2 pt-2">
                                        <label for="caroJoinCodeInput" class="block text-[10px] font-black text-gray-500 uppercase tracking-widest pl-1">
                                            MÃ PIN PHÒNG CHƠI
                                        </label>
                                        <input type="text" id="caroJoinCodeInput" maxlength="4" autocomplete="off" placeholder="Ví dụ: 4812" 
                                               class="w-full bg-neutral-900 border border-neutral-800 focus:border-cyan-500/50 rounded-xl px-3 py-2.5 text-xs text-white font-bold outline-none transition uppercase text-center tracking-widest">
                                    </div>
                                </div>
                                <button id="btnCaroJoinRoom" class="w-full bg-cyan-500 hover:bg-cyan-400 text-black py-3 rounded-xl font-black text-xs tracking-wider transition duration-150 shadow-lg shadow-cyan-500/10 mt-4">
                                    THAM GIA PHÒNG ⚔️
                                </button>
                            </div>
                        </div>

                        <div class="flex justify-center pt-4">
                            <button onclick="location.href='/minigame'" class="bg-red-950/40 hover:bg-red-950/80 text-red-400 font-extrabold text-[10px] px-8 py-3 rounded-xl border border-red-900/30 transition tracking-wider flex items-center gap-1.5 shadow-md">
                                🚪 THOÁT RA KHO GAME
                            </button>
                        </div>
                    </div>

                    <!-- 2. MÀN HÌNH ĐỢI BẠN CHƠI (WAITING PANEL) -->
                    <div id="caroWaitingPanel" class="hidden space-y-6 py-6">
                        <div class="text-center space-y-3">
                            <span class="text-5xl block animate-pulse">📡</span>
                            <h3 class="text-lg font-black text-amber-500 uppercase tracking-widest">ĐANG ĐỢI ĐỐI THỦ THAM GIA...</h3>
                            <p class="text-xs text-neutral-400">Hãy gửi mã PIN phòng dưới đây cho bạn bè trên cùng mạng LAN:</p>
                            
                            <div class="inline-block bg-neutral-950 px-8 py-4 rounded-3xl border border-neutral-800 shadow-inner">
                                <span class="text-neutral-500 text-[10px] uppercase font-black tracking-widest block mb-1">MÃ PHÒNG</span>
                                <span id="caroWaitingCode" class="text-4xl font-mono font-black text-cyan-400 tracking-wider animate-pulse">----</span>
                            </div>
                        </div>

                        <!-- Cặp đấu hiển thị -->
                        <div class="flex items-center justify-center gap-6 max-w-md mx-auto pt-4 select-none">
                            <div class="flex-1 bg-neutral-950 p-4 rounded-2xl border border-cyan-500/30 text-center space-y-2">
                                <img src="/img/caro/blue.png" class="w-16 h-16 mx-auto object-contain">
                                <span id="caroWaitingP1Name" class="block font-bold text-xs text-white truncate">Bạn</span>
                                <span class="text-[9px] font-black text-cyan-400 bg-cyan-950/40 px-2 py-0.5 rounded-full border border-cyan-900">QUÂN XANH (X)</span>
                            </div>
                            <span class="text-neutral-600 font-black text-sm">VS</span>
                            <div class="flex-1 bg-neutral-950 p-4 rounded-2xl border border-neutral-800 text-center space-y-2 opacity-60">
                                <div class="w-16 h-16 mx-auto flex items-center justify-center border-4 border-dashed border-neutral-800 rounded-full animate-spin">
                                    <span class="text-xs text-neutral-600 animate-none">⏳</span>
                                </div>
                                <span class="block font-bold text-xs text-neutral-500 italic">Đang chờ...</span>
                                <span class="text-[9px] font-black text-neutral-600 bg-neutral-900 px-2 py-0.5 rounded-full border border-neutral-850">QUÂN ĐỎ (O)</span>
                            </div>
                        </div>

                        <div class="flex justify-center pt-4">
                            <button id="btnCaroCancelWaiting" class="bg-red-950/40 hover:bg-red-950/80 text-red-400 font-extrabold text-[10px] px-8 py-3 rounded-xl border border-red-900/30 transition tracking-wider flex items-center gap-1.5 shadow-md">
                                🚪 HỦY PHÒNG / THOÁT
                            </button>
                        </div>
                    </div>

                    <!-- 3. MÀN HÌNH BÀN CHƠI (MATCH PLAY PANEL) -->
                    <div id="caroMatchPanel" class="hidden flex flex-col lg:flex-row gap-6 relative">
                        
                        <!-- Cột Trái: Chỉ số & Đếm ngược -->
                        <div class="w-full lg:w-60 bg-neutral-950 p-4 rounded-2xl border border-neutral-850/60 flex flex-row lg:flex-col justify-between lg:justify-start gap-4 text-xs font-bold shrink-0 shadow-inner">
                            <div class="space-y-4 w-full flex-grow flex flex-col">
                                <div class="flex items-center justify-between border-b border-neutral-850 pb-2">
                                    <h3 class="text-cyan-500 text-[10px] tracking-wider uppercase font-black">📊 TRẬN ĐẤU LAN</h3>
                                    <span class="text-[10px] text-gray-500 font-mono" id="caroMatchCodeDisplay">Phòng #----</span>
                                </div>

                                <!-- Cặp kỳ thủ đấu -->
                                <div class="space-y-3 pt-1">
                                    <!-- Người chơi 1 -->
                                    <div id="caroPlayer1Card" class="flex items-center gap-2 p-2 rounded-xl border border-neutral-900 transition-all duration-300">
                                        <img src="/img/caro/blue.png" class="w-10 h-10 object-contain">
                                        <div class="flex-grow min-w-0">
                                            <span id="caroP1Name" class="block text-white truncate text-xs font-black">---</span>
                                            <span class="text-[9px] text-cyan-400 font-black">QUÂN XANH (X)</span>
                                        </div>
                                    </div>
                                    <div class="text-center text-[10px] text-neutral-600 font-black tracking-widest my-0">VS</div>
                                    <!-- Người chơi 2 -->
                                    <div id="caroPlayer2Card" class="flex items-center gap-2 p-2 rounded-xl border border-neutral-900 transition-all duration-300">
                                        <img src="/img/caro/red.png" class="w-10 h-10 object-contain">
                                        <div class="flex-grow min-w-0">
                                            <span id="caroP2Name" class="block text-white truncate text-xs font-black">---</span>
                                            <span class="text-[9px] text-rose-500 font-black">QUÂN ĐỎ (O)</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Lượt đi hiện tại -->
                                <div class="bg-neutral-900/60 p-2.5 rounded-xl border border-neutral-850 text-center space-y-1">
                                    <span class="text-gray-500 text-[9px] uppercase font-black">LƯỢT ĐI HIỆN TẠI:</span>
                                    <div id="caroTurnIndicator" class="text-xs font-black text-white uppercase tracking-wider animate-pulse">ĐANG CẬP NHẬT...</div>
                                </div>

                                <!-- Đếm ngược lượt -->
                                <div class="space-y-1.5 pt-2">
                                    <div class="flex justify-between text-[9px] text-gray-500 font-black uppercase">
                                        <span>⏳ Đếm ngược suy nghĩ</span>
                                        <span id="caroTimerText" class="text-cyan-400 font-mono">30s</span>
                                    </div>
                                    <div class="h-3.5 bg-neutral-900 rounded-full overflow-hidden border border-neutral-800 p-0.5 w-full shadow-inner">
                                        <div id="caroTimerBar" class="h-full bg-gradient-to-r from-cyan-500 to-indigo-500 rounded-full transition-all duration-100 shadow-[0_0_10px_rgba(6,182,212,0.4)]" style="width: 100%;"></div>
                                    </div>
                                </div>
                            </div>

                            <button id="btnCaroLeaveMatch" class="w-full bg-red-950/40 hover:bg-red-950/80 text-red-400 font-extrabold text-[10px] py-3 rounded-xl border border-red-900/30 transition tracking-wider flex items-center justify-center gap-1.5 shadow-md mt-auto">
                                🚪 XIN HÒA / THOÁT
                            </button>
                        </div>

                        <!-- Khung Chơi Game Trung Tâm (Canvas) -->
                        <div class="flex-grow flex items-center justify-center relative min-h-[350px] md:min-h-[500px] lg:min-h-[580px]">
                            <canvas id="caroCanvas" class="bg-neutral-950 rounded-2xl border border-neutral-850 shadow-inner w-full max-w-[580px] aspect-square block"></canvas>
                        </div>

                        <!-- Cột Phải: LAN Chat Box -->
                        <div class="w-full lg:w-72 bg-neutral-950 p-4 rounded-2xl border border-neutral-850/60 flex flex-col justify-between gap-4 text-xs shrink-0 shadow-inner">
                            <div class="flex flex-col h-full space-y-3">
                                <h3 class="text-cyan-500 text-[10px] tracking-wider uppercase font-black border-b border-neutral-850 pb-2">💬 LAN CHAT BOX</h3>
                                
                                <!-- Hộp tin nhắn chat -->
                                <div id="caroChatHistory" class="flex-grow h-48 lg:h-80 bg-neutral-900/40 border border-neutral-850 rounded-xl p-3 overflow-y-auto space-y-2.5 custom-scrollbar text-[11px] font-bold">
                                    <div class="text-center text-neutral-600 font-medium italic select-none py-12">Phòng chat đã được kết nối an toàn qua LAN!</div>
                                </div>

                                <!-- Chat Input & Send Button -->
                                <div class="flex gap-2">
                                    <input type="text" id="caroChatInput" maxlength="100" placeholder="Nhập tin nhắn..." autocomplete="off"
                                           class="flex-grow bg-neutral-900 border border-neutral-850 focus:border-cyan-500/50 rounded-xl px-3 py-2 text-xs text-white font-bold outline-none transition">
                                    <button id="btnCaroSendChat" class="bg-cyan-500 hover:bg-cyan-400 text-black px-3.5 rounded-xl font-black transition-all shadow-md shadow-cyan-500/10">
                                        GỬI
                                    </button>
                                </div>

                                <!-- Khay Phím tắt gáy nhanh -->
                                <div class="space-y-1.5 pt-2">
                                    <span class="text-[9px] text-gray-500 font-black uppercase tracking-wider block">🗣️ GÁY NHANH:</span>
                                    <div class="grid grid-cols-2 gap-1.5">
                                        <button class="btn-caro-quick-chat bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] font-bold text-gray-300 py-1.5 rounded-lg transition" data-msg="Gà quá! 🐔">Gà quá! 🐔</button>
                                        <button class="btn-caro-quick-chat bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] font-bold text-gray-300 py-1.5 rounded-lg transition" data-msg="Đi nhanh lên bạn ơi! ⏳">Đi nhanh! ⏳</button>
                                        <button class="btn-caro-quick-chat bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] font-bold text-gray-300 py-1.5 rounded-lg transition" data-msg="Lbeo phù hộ tôi! 👼">Lbeo độ! 👼</button>
                                        <button class="btn-caro-quick-chat bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] font-bold text-gray-300 py-1.5 rounded-lg transition" data-msg="Ăn hành rồi con trai! 🧅">Ăn hành! 🧅</button>
                                        <button class="btn-caro-quick-chat bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] font-bold text-gray-300 py-1.5 rounded-lg transition" data-msg="Hên thôi nhé! 😏">Hên thôi! 😏</button>
                                        <button class="btn-caro-quick-chat bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] font-bold text-gray-300 py-1.5 rounded-lg transition" data-msg="Đầu hàng đi! 🏳️">Đầu hàng! 🏳️</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Lớp Phủ Kết Quả Trận Đấu (Meme Overlay) -->
                        <div id="caroResultOverlay" class="absolute inset-0 bg-neutral-950/85 backdrop-blur-md z-40 hidden flex flex-col items-center justify-center p-4 rounded-3xl transition-all duration-300">
                            <div class="w-full max-w-md bg-neutral-900 border border-neutral-800 rounded-3xl p-6 shadow-2xl space-y-6 text-center transform scale-95 transition-all duration-300 relative overflow-hidden">
                                
                                <!-- Background Glow -->
                                <div id="caroResultGlow" class="absolute -top-16 -left-16 w-32 h-32 bg-cyan-500/10 rounded-full filter blur-2xl pointer-events-none"></div>
                                
                                <div class="space-y-2 relative">
                                    <span id="caroResultEmoji" class="text-6xl block animate-bounce">🏆</span>
                                    <h3 id="caroResultTitle" class="text-xl font-black text-cyan-400 uppercase tracking-widest">CHIẾN THẮNG QUÁ THUYẾT PHỤC!</h3>
                                    <p id="caroResultMsg" class="text-xs text-neutral-400 font-bold leading-relaxed px-4">Bạn đã đánh bại đối thủ bằng nước cờ chặn hai đầu hiểm độc.</p>
                                </div>

                                <!-- Meme hiển thị -->
                                <div class="relative w-44 h-44 mx-auto bg-neutral-950 rounded-2xl border border-neutral-850 flex items-center justify-center overflow-hidden shadow-inner p-2 group">
                                    <img id="caroResultMeme" src="/img/beo-dino/characters/6.png" class="w-full h-full object-contain transform group-hover:scale-105 transition-transform duration-300">
                                </div>

                                <div class="flex justify-center relative">
                                    <button id="btnCaroCloseResult" class="bg-cyan-500 hover:bg-cyan-400 text-black font-black text-xs px-10 py-3.5 rounded-2xl transition shadow-lg shadow-cyan-500/20 tracking-wider flex items-center gap-2">
                                        🎮 TRỞ VỀ SẢNH CHỜ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>
    </div>

    <!-- Container Toast -->
    <div id="toastContainer" class="fixed bottom-5 right-5 z-50 flex flex-col gap-2 max-w-sm w-full pointer-events-none"></div>

    <!-- Core Game Scripts -->
    <link rel="stylesheet" href="/css/caro.css?v=<%= version %>">
    <script src="/socket.io/socket.io.js"></script>
    <script type="module" src="/js/ui.js?v=<%= version %>"></script>
    <script type="module" src="/js/caro.js?v=<%= version %>"></script>
    <script type="module">
        import { showToast } from '/js/ui.js';
        window.showToast = showToast;
    </script>
</body>
</html>
