<%- include('partials/head', { title: 'BeoHub - Share Tốc Độ Cao Mạng LAN' }) %><body class="min-h-screen font-sans text-gray-300">
    <div class="container mx-auto p-4 max-w-6xl">

        <%- include('partials/nav', { isHome: true }) %>

        <!-- HOME / MAIN SECTION -->
        <section id="homeSection" class="transition-all duration-300">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <!-- Khu Vực Upload (Bên trái) -->
                <div id="uploadContainer" class="bg-ph-dark p-4 rounded-xl border border-neutral-800 h-fit md:col-span-1 shadow-2xl">
                    <h2
                        class="text-base font-bold mb-4 text-white uppercase tracking-wide border-b border-neutral-800 pb-2 flex items-center gap-1">
                        <span>📤</span> Tải nội dung lên
                    </h2>
                    <form id="uploadForm" class="space-y-4">

                        <div id="dropzone"
                            class="border-2 border-dashed border-neutral-700 rounded-xl p-5 text-center cursor-pointer hover:border-ph-orange hover:bg-neutral-800 transition-all relative group bg-neutral-900">
                            <input type="file" id="fileInput" multiple accept="image/*,video/*" class="hidden">
                            <div class="space-y-2 pointer-events-none">
                                <div class="text-2xl transition-transform group-hover:scale-110">🎥</div>
                                <p class="text-xs font-bold text-gray-400">Kéo thả Ảnh / Video vào đây</p>
                                <p class="text-[11px] text-gray-600">hoặc <span class="text-ph-orange underline">duyệt file
                                        máy tính</span></p>
                            </div>
                            <div id="fileCounter" class="mt-2 text-xs font-bold text-ph-orange hidden"></div>
                        </div>

                        <!-- DANH SÁCH LOOP XEM TRƯỚC VÀ ĐẶT TÊN RIÊNG BIỆT TỪNG FILE -->
                        <div id="previewContainer" class="hidden space-y-2">
                            <label class="block text-[11px] font-bold text-neutral-400 uppercase tracking-wider">Cấu hình
                                tên tệp tin chọn</label>
                            <!-- Thùng chứa dạng list cuộn dọc, giao diện tối sẫm -->
                            <div id="previewGrid"
                                class="space-y-3 p-2 bg-neutral-900 border border-neutral-800 rounded-lg max-h-64 overflow-y-auto custom-scrollbar">
                                <!-- JS loop chèn các row vào đây -->
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1">Hashtags
                                chung (Dấu phẩy phân cách)</label>
                            <input type="text" id="tagsInput" placeholder="Ví dụ: meme, hot"
                                class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white focus:outline-none focus:border-ph-orange transition">
                        </div>
                        <div>
                            <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1">Mô tả chung chi tiết</label>
                            <textarea id="descInput" rows="2" placeholder="Nhập mô tả ngắn..."
                                class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white focus:outline-none focus:border-ph-orange transition"></textarea>
                        </div>
                        <div>
                            <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1">Nơi hiển thị hình ảnh</label>
                            <select id="uploadCategorySelect" class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white focus:outline-none focus:border-ph-orange transition">
                                <option value="home">🏠 Trang chủ</option>
                                <option value="lbeo">🖤 Sản phẩm của Lbeo</option>
                            </select>
                        </div>
                        <button type="submit"
                            class="w-full bg-ph-orange text-black py-2.5 rounded-lg font-bold text-sm hover:bg-amber-500 transition duration-150 shadow-md">BẮT
                            ĐẦU UPLOAD</button>
                    </form>
                </div>

                <!-- Khu Vực Thư Viện Media (Bên phải) -->
                <div id="galleryContainer" class="md:col-span-3 space-y-4">
                    <div id="lbeoBanner" class="hidden bg-neutral-900 border border-neutral-800 rounded-xl p-5 flex items-center gap-4 shadow-xl">
                        <div class="text-3xl">🖤</div>
                        <div>
                            <h2 class="text-base font-bold text-white uppercase tracking-wider">Sản Phẩm Độc Quyền Từ Lbeo</h2>
                            <p class="text-[11px] text-gray-400">Nơi tổng hợp những tác phẩm truyền thông độc quyền của thần tượng Lbeo.</p>
                        </div>
                    </div>
                    <div class="w-full relative">
                        <input type="text" id="searchInput"
                            placeholder="🔍 Nhập tên file, định dạng hoặc hashtag cần tìm..."
                            class="w-full p-3.5 bg-ph-dark rounded-xl border border-neutral-800 text-white focus:outline-none focus:border-ph-orange transition text-sm shadow-xl pl-5 placeholder-gray-600">
                    </div>
                    <div id="galleryGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
                </div>
            </div>
        </section>

        <!-- NEWS SECTION -->
        <section id="newsSection" class="hidden transition-all duration-300">
            <div class="max-w-4xl mx-auto space-y-6">
                <div class="text-center space-y-2 mb-6">
                    <h2 class="text-xl font-black text-white uppercase tracking-wider flex items-center justify-center gap-2">
                        <span>📰</span> Tin Tức Mới Nhất
                    </h2>
                    <p class="text-xs text-neutral-400 max-w-md mx-auto leading-relaxed">
                        Cập nhật các thông tin, sự kiện và thông báo mới nhất từ BeoHub.
                    </p>
                </div>
                <div id="publicNewsList" class="space-y-4">
                     <div class="text-center py-10 text-neutral-500 text-xs font-bold">
                         Đang tải tin tức...
                     </div>
                </div>
            </div>
        </section>

        <!-- IDEAS CONTRIBUTION SECTION -->
        <section id="ideasSection" class="hidden transition-all duration-300">
            <div class="max-w-2xl mx-auto bg-ph-dark p-6 md:p-8 rounded-2xl border border-neutral-800 shadow-2xl space-y-6">
                <div class="text-center space-y-2">
                    <h2 class="text-xl font-black text-white uppercase tracking-wider flex items-center justify-center gap-2">
                        <span>🎭</span> Ghép mặt Lbeo AI
                    </h2>
                    <p class="text-xs text-neutral-400 max-w-md mx-auto leading-relaxed">
                        Tải một bức ảnh lên, AI sẽ tự động ghép khuôn mặt độc quyền!
                    </p>
                </div>

                <form id="faceSwapForm" class="space-y-4">
                    <div class="border-2 border-dashed border-neutral-850 hover:border-ph-orange rounded-xl p-6 text-center cursor-pointer transition-all relative bg-neutral-900/50 group" onclick="document.getElementById('faceSwapInput').click()">
                        <input type="file" id="faceSwapInput" accept="image/*" class="hidden">
                        <div class="space-y-2 pointer-events-none">
                            <div id="faceSwapPreviewContainer" class="hidden aspect-square w-32 mx-auto bg-neutral-950 rounded-lg overflow-hidden border border-neutral-800 relative flex items-center justify-center shadow-inner mb-2 animate-slide-in">
                                <img id="faceSwapPreviewImg" src="" class="w-full h-full object-cover">
                            </div>
                            <div id="faceSwapIcon" class="text-3xl transition-transform group-hover:scale-110">📸</div>
                            <span id="faceSwapLabel" class="text-neutral-400 text-xs block font-bold">Chọn bức ảnh bạn muốn bị ghép mặt (JPG/PNG)</span>
                            <span id="faceSwapCounter" class="text-xs text-emerald-400 font-extrabold hidden">✓ Đã chọn ảnh thành công!</span>
                        </div>
                    </div>
                    <button type="submit" id="faceSwapBtn" class="w-full bg-ph-orange hover:bg-amber-500 text-black font-black text-xs py-3 rounded-xl transition duration-250 tracking-wide flex items-center justify-center gap-2 shadow-lg shadow-ph-orange/10">
                        <span>🚀 BẮT ĐẦU HOÁN ĐỔI</span>
                    </button>
                </form>
                
                <!-- Hiển thị kết quả -->
                <div id="faceSwapResultContainer" class="hidden space-y-4 pt-6 border-t border-neutral-800/80 animate-slide-in">
                    <h4 class="text-xs font-black text-ph-orange text-center uppercase tracking-widest">✨ Kết quả ghép mặt AI ✨</h4>
                    <div class="aspect-square w-full max-w-md mx-auto bg-neutral-950 rounded-xl overflow-hidden border border-neutral-800 relative flex items-center justify-center shadow-inner">
                        <img id="faceSwapResultImg" src="" class="w-full h-full object-cover">
                    </div>
                    
                    <!-- Nhập Metadata trước khi upload -->
                    <div class="max-w-md mx-auto space-y-3 bg-neutral-900/60 p-4 rounded-xl border border-neutral-800/80">
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Tên tệp tin tùy chỉnh (không cần đuôi .webp)</label>
                            <input type="text" id="faceSwapResultNameInput" value="lbeo_swapped" placeholder="Nhập tên tệp..."
                                class="w-full p-2 bg-neutral-950 border border-neutral-850 rounded-lg text-xs text-white focus:outline-none focus:border-ph-orange transition">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Mô tả bức ảnh</label>
                            <textarea id="faceSwapResultDescInput" rows="2" placeholder="Nhập mô tả cho bức ảnh ghép mặt..."
                                class="w-full p-2 bg-neutral-950 border border-neutral-850 rounded-lg text-xs text-white focus:outline-none focus:border-ph-orange transition">Ảnh ghép mặt Lbeo AI cực độc!</textarea>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Nơi hiển thị hình ảnh</label>
                            <select id="faceSwapResultCategorySelect" class="w-full p-2 bg-neutral-950 border border-neutral-850 rounded-lg text-xs text-white focus:outline-none focus:border-ph-orange transition">
                                <option value="home">🏠 Trang chủ</option>
                                <option value="lbeo">🖤 Sản phẩm của Lbeo</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex gap-3 max-w-md mx-auto">
                        <a id="downloadSwappedBtn" href="#" download="lbeo_swapped.webp" class="flex-1 text-center bg-neutral-800 hover:bg-neutral-700 text-gray-300 font-extrabold text-[11px] py-2.5 rounded-xl transition tracking-wide border border-neutral-700">📥 TẢI KẾT QUẢ</a>
                        <button id="uploadSwappedBtn" class="flex-1 bg-ph-orange hover:bg-amber-500 text-black font-black text-[11px] py-2.5 rounded-xl transition tracking-wide flex items-center justify-center gap-1.5 shadow-lg shadow-ph-orange/10">
                            <span>📤 ĐĂNG LÊN BEOHUB</span>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- Container Toast -->
    <div id="toastContainer"
        class="fixed bottom-5 right-5 z-50 flex flex-col gap-2 max-w-sm w-full pointer-events-none"></div>

    <!-- MODAL CHI TIẾT SPLIT-SCREEN -->
    <div id="mediaModal"
        class="fixed inset-0 bg-black bg-opacity-95 hidden z-50 flex items-center justify-center p-0 md:p-6 transition-all duration-200"
        onclick="closeModal()">
        <div class="relative bg-ph-dark w-full max-w-5xl h-full md:h-[85vh] flex flex-col md:flex-row rounded-none md:rounded-xl overflow-hidden border border-neutral-800 shadow-2xl"
            onclick="event.stopPropagation()">
            <span
                class="absolute top-3 right-4 text-white text-3xl font-light cursor-pointer hover:text-ph-orange transition z-50 md:hidden"
                onclick="closeModal()">&times;</span>
            <div
                class="w-full md:w-3/5 h-1/2 md:h-full bg-black flex items-center justify-center relative border-b md:border-b-0 md:border-r border-neutral-800">
                <!-- Nút chuyển sang trái -->
                <button id="prevBtn" class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/80 text-white/60 hover:text-white w-10 h-10 rounded-full flex items-center justify-center transition border border-white/10 z-50 shadow-lg cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                    </svg>
                </button>

                <div id="modalContent" class="w-full h-full flex items-center justify-center p-2"></div>

                <!-- Nút chuyển sang phải -->
                <button id="nextBtn" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/80 text-white/60 hover:text-white w-10 h-10 rounded-full flex items-center justify-center transition border border-white/10 z-50 shadow-lg cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                </button>
            </div>
            <div class="w-full md:w-2/5 h-1/2 md:h-full flex flex-col justify-between bg-ph-dark p-4">
                <div class="border-b border-neutral-800 pb-3 relative">
                    <span
                        class="absolute top-0 right-0 text-white text-4xl font-light cursor-pointer hover:text-ph-orange transition hidden md:block"
                        onclick="closeModal()">&times;</span>
                    <h3 id="modalTitle" class="font-bold text-white text-base truncate pr-8"></h3>
                    <p id="modalDesc" class="text-xs text-neutral-400 mt-1 leading-relaxed line-clamp-2"></p>
                    <div id="modalTags" class="flex flex-wrap gap-1 mt-2"></div>
                </div>
                <div class="flex items-center justify-between py-2 border-b border-neutral-800">
                    <div class="flex items-center gap-3">
                        <div class="flex items-center gap-1.5">
                            <button id="likeBtn"
                                class="flex items-center gap-1 bg-neutral-900 border border-neutral-800 hover:border-ph-orange px-2.5 py-1.5 rounded-lg group transition">
                                <span class="text-xs group-hover:scale-125 transition duration-150">❤️</span>
                                <span class="text-[10px] font-bold text-white tracking-wide">THẢ TIM</span>
                            </button>
                            <div class="text-[10px] font-bold text-neutral-400"><span id="likeCount"
                                    class="text-ph-orange text-xs font-mono">0</span></div>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <button id="hahaBtn"
                                class="flex items-center gap-1 bg-neutral-900 border border-neutral-800 hover:border-ph-orange px-2.5 py-1.5 rounded-lg group transition">
                                <span class="text-xs group-hover:scale-125 transition duration-150">😆</span>
                                <span class="text-[10px] font-bold text-white tracking-wide">HAHA</span>
                            </button>
                            <div class="text-[10px] font-bold text-neutral-400"><span id="hahaCount"
                                    class="text-ph-orange text-xs font-mono">0</span></div>
                        </div>
                    </div>
                    <button id="shareLinkBtn"
                        class="flex items-center gap-1.5 bg-neutral-900 border border-neutral-800 hover:border-ph-orange px-3 py-2 rounded-lg text-white font-bold text-[11px] tracking-wide transition">🔗
                        COPY LINK SHARE</button>
                </div>
                <div class="flex-grow overflow-y-auto py-3 space-y-3 custom-scrollbar" id="commentsContainer"></div>
                <form id="commentForm" class="border-t border-neutral-800 pt-3 flex gap-2">
                    <input type="text" id="commentInput" placeholder="Viết bình luận công khai (ẩn danh)..."
                        autocomplete="off"
                        class="flex-grow p-2.5 bg-neutral-900 border border-neutral-800 rounded-lg text-xs text-white focus:outline-none focus:border-ph-orange transition placeholder-neutral-600">
                    <button type="submit"
                        class="bg-ph-orange text-black px-4 rounded-lg text-xs font-black hover:bg-amber-500 transition tracking-wider whitespace-nowrap">GỬI</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Sửa Thông Tin -->
    <div id="editModal" class="fixed inset-0 bg-black bg-opacity-70 hidden z-40 flex items-center justify-center p-4">
        <div class="bg-ph-dark rounded-xl shadow-2xl max-w-md w-full p-6 space-y-4 relative border border-neutral-800">
            <span
                class="absolute top-2 right-4 text-gray-500 hover:text-white text-2xl font-bold cursor-pointer transition"
                onclick="closeEditModal()">&times;</span>
            <h3 class="text-base font-bold text-white border-b border-neutral-800 pb-2 uppercase tracking-wider">✏️
                Chỉnh sửa nội dung</h3>
            <form id="editForm" class="space-y-4">
                <input type="hidden" id="editOldName">
                <div>
                    <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1">Tên tệp tin
                        (Tự động lọc sạch dấu)</label>
                    <input type="text" id="editNewNameInput"
                        class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white font-medium focus:outline-none focus:border-ph-orange transition">
                </div>
                <div>
                    <label
                        class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1">Hashtags</label>
                    <input type="text" id="editTagsInput"
                        class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white focus:outline-none focus:border-ph-orange transition">
                </div>
                <div>
                    <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1">Mô tả nội dung</label>
                    <textarea id="editDescInput" rows="3"
                        class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white focus:outline-none focus:border-ph-orange transition"></textarea>
                </div>
                <div>
                    <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1">Nơi hiển thị hình ảnh</label>
                    <select id="editCategorySelect" class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white focus:outline-none focus:border-ph-orange transition">
                        <option value="home">🏠 Trang chủ</option>
                        <option value="lbeo">🖤 Sản phẩm của Lbeo</option>
                    </select>
                </div>
                <div class="flex gap-2 justify-end pt-2 border-t border-neutral-800">
                    <button type="button" onclick="closeEditModal()"
                        class="px-4 py-2 text-xs font-bold text-gray-400 hover:text-white bg-neutral-900 border border-neutral-800 rounded-lg transition">HỦY
                        BỎ</button>
                    <button type="submit"
                        class="px-4 py-2 text-xs font-bold text-black bg-ph-orange hover:bg-amber-500 rounded-lg transition shadow-md">LƯU
                        THAY ĐỔI</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/game.js"></script>
    <script type="module" src="/js/app.js"></script>
</body>

</html>