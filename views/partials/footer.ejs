                    <div>
                        <label class="text-[9px] font-bold text-gray-500 block mb-0.5">TÊN NGƯỜI DONATE</label>
                        <input type="text" id="donateNameInput" required placeholder="Ví dụ: Chủ tịch Jun" class="w-full p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-xs text-white focus:outline-none focus:border-amber-500 transition">
