<%- include('partials/head', { title: 'Kho Minigame BeoHub' }) %>
<body class="min-h-screen font-outfit text-gray-300">
    <div class="w-full px-4 md:px-8 py-4">
        <%- include('partials/nav', { isMinigame: true }) %>

        <!-- MINIGAME CONTENT -->
        <section id="minigameSection" class="transition-all duration-300 max-w-[1440px] mx-auto">
            <div id="minigameContainer" class="w-full space-y-6 transition-all duration-500">
                <!-- Màn hình chính Minigames -->
                <div id="minigameHome" class="bg-ph-dark p-6 md:p-8 rounded-2xl border border-neutral-800 shadow-2xl space-y-6">
                    <div class="text-center space-y-2">
                        <h2 class="text-xl font-black text-white uppercase tracking-wider flex items-center justify-center gap-2">
                            <span>🎮</span> KHO MINIGAME BEOHUB
                        </h2>
                        <p class="text-xs text-neutral-400 max-w-md mx-auto leading-relaxed">
                            Thư giãn cùng những trò chơi giải trí hại não phiên bản Lbeo độc quyền!
                        </p>
                    </div>

                    <!-- Danh sách trò chơi -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-2">
                        <% if (isAdmin || (gameSettings && gameSettings.pikabeo)) { %>
                        <!-- Thẻ game Pikabeo -->
                        <div class="bg-neutral-900/60 p-5 rounded-2xl border border-neutral-800/80 hover:border-amber-500/30 transition duration-300 flex flex-col justify-between space-y-4 shadow-lg group relative overflow-hidden">
                            <% if (gameSettings && !gameSettings.pikabeo) { %>
                                <span class="bg-red-500 px-3 py-1 text-[10px] font-black text-white absolute top-0 right-0 rounded-bl-lg shadow-md z-10">TEST MODE</span>
                            <% } %>
                            <div class="space-y-2 mt-1">
                                <div class="flex items-center justify-between">
                                    <span class="text-xs font-bold text-amber-500 bg-amber-500/10 px-2.5 py-0.5 rounded-full">Classic Onet</span>
                                    <span class="text-xs text-gray-500 font-medium">Phiên bản 1.0</span>
                                </div>
                                <h3 class="text-lg font-black text-white group-hover:text-amber-400 transition">⚡ Pikabeo Onet Connect</h3>
                                <p class="text-xs text-neutral-400 leading-relaxed">
                                    Trò chơi Pikachu 2003 cổ điển cực kỳ quen thuộc! Kết nối các cặp thẻ Lbeo giống nhau để hé lộ dần bức **Ảnh Bí Mật** do Admin giấu kín ở phía dưới. Giải mã toàn bộ màn chơi trước khi hết giờ để chiến thắng!
                                </p>
                            </div>
                            <button id="btnStartPikabeo" onclick="location.href='/minigame/pikabeo'" class="w-full bg-amber-500 hover:bg-amber-400 text-black py-2.5 rounded-xl font-black text-xs tracking-wider transition duration-150 shadow-lg shadow-amber-500/10">
                                CHƠI NGAY 🎮
                            </button>
                        </div>
                        <% } %>

                        <% if (isAdmin || (gameSettings && gameSettings.dino)) { %>
                        <!-- Thẻ game Dino -->
                        <div class="bg-neutral-900/60 p-5 rounded-2xl border border-neutral-800/80 hover:border-emerald-500/30 transition duration-300 flex flex-col justify-between space-y-4 shadow-lg group relative overflow-hidden">
                            <% if (gameSettings && !gameSettings.dino) { %>
                                <span class="bg-red-500 px-3 py-1 text-[10px] font-black text-white absolute top-0 right-0 rounded-bl-lg shadow-md z-10">TEST MODE</span>
                            <% } %>
                            <div class="space-y-2 mt-1">
                                <div class="flex items-center justify-between">
                                    <span class="text-xs font-bold text-emerald-500 bg-emerald-500/10 px-2.5 py-0.5 rounded-full">Endless Runner</span>
                                    <span class="text-xs text-gray-500 font-medium">Phiên bản 1.0</span>
                                </div>
                                <h3 class="text-lg font-black text-white group-hover:text-emerald-400 transition">🦖 Beo Dino Run</h3>
                                <p class="text-xs text-neutral-400 leading-relaxed">
                                    Trò chơi khủng long mất mạng huyền thoại, nhưng nay đã được thay thế bằng cậu bé áo vàng Lbeo! Nhảy qua các chướng ngại vật và chạy xa nhất có thể.
                                </p>
                            </div>
                            <button id="btnStartDino" onclick="location.href='/minigame/beorun'" class="w-full bg-emerald-500 hover:bg-emerald-400 text-black py-2.5 rounded-xl font-black text-xs tracking-wider transition duration-150 shadow-lg shadow-emerald-500/10">
                                CHƠI NGAY 🏃
                            </button>
                        </div>
                        <% } %>

                        <% if (isAdmin || (gameSettings && gameSettings.dobeo)) { %>
                        <!-- Thẻ game Dò Beo -->
                        <div class="bg-neutral-900/60 p-5 rounded-2xl border border-neutral-800/80 hover:border-blue-500/30 transition duration-300 flex flex-col justify-between space-y-4 shadow-lg group relative overflow-hidden">
                            <% if (gameSettings && !gameSettings.dobeo) { %>
                                <span class="bg-red-500 px-3 py-1 text-[10px] font-black text-white absolute top-0 right-0 rounded-bl-lg shadow-md z-10">TEST MODE</span>
                            <% } %>
                            <div class="space-y-2 mt-1">
                                <div class="flex items-center justify-between">
                                    <span class="text-xs font-bold text-blue-500 bg-blue-500/10 px-2.5 py-0.5 rounded-full">Minesweeper</span>
                                    <span class="text-xs text-gray-500 font-medium">Phiên bản 1.0</span>
                                </div>
                                <h3 class="text-lg font-black text-white group-hover:text-blue-400 transition">💣 Dò Beo</h3>
                                <p class="text-xs text-neutral-400 leading-relaxed">
                                    Một phiên bản siêu bựa của Minesweeper. Đừng đánh thức Lbeo nếu không muốn phải uống phạt! Cắm ly bia để đánh dấu và mở hết đĩa lạc.
                                </p>
                            </div>
                            <button id="btnStartDobeo" onclick="location.href='/minigame/dobeo'" class="w-full bg-blue-500 hover:bg-blue-400 text-black py-2.5 rounded-xl font-black text-xs tracking-wider transition duration-150 shadow-lg shadow-blue-500/10">
                                CHƠI NGAY 🍺
                            </button>
                        </div>
                        <% } %>

                        <% if (isAdmin || (gameSettings && gameSettings.caro)) { %>
                        <!-- Thẻ game Caro -->
                        <div class="bg-neutral-900/60 p-5 rounded-2xl border border-neutral-800/80 hover:border-cyan-500/30 transition duration-300 flex flex-col justify-between space-y-4 shadow-lg group relative overflow-hidden">
                            <% if (gameSettings && !gameSettings.caro) { %>
                                <span class="bg-red-500 px-3 py-1 text-[10px] font-black text-white absolute top-0 right-0 rounded-bl-lg shadow-md z-10">TEST MODE</span>
                            <% } %>
                            <div class="space-y-2 mt-1">
                                <div class="flex items-center justify-between">
                                    <span class="text-xs font-bold text-cyan-500 bg-cyan-500/10 px-2.5 py-0.5 rounded-full">Caro LAN</span>
                                    <span class="text-xs text-gray-500 font-medium">Phiên bản 1.0</span>
                                </div>
                                <h3 class="text-lg font-black text-white group-hover:text-cyan-400 transition">⭕ Beo Caro LAN Online</h3>
                                <p class="text-xs text-neutral-400 leading-relaxed">
                                    Trò chơi cờ Caro (Gomoku) 15x15 hấp dẫn thời gian thực qua mạng nội bộ LAN! Trận đấu kịch tính với đồng hồ đếm ngược tùy chỉnh và luật chặn hai đầu đầy tính chiến thuật. Chat trực tuyến giao lưu cùng bạn chơi!
                                </p>
                            </div>
                            <button id="btnStartCaro" onclick="location.href='/minigame/caro'" class="w-full bg-cyan-500 hover:bg-cyan-400 text-black py-2.5 rounded-xl font-black text-xs tracking-wider transition duration-150 shadow-lg shadow-cyan-500/10">
                                CHƠI NGAY ⚔️
                            </button>
                        </div>
                        <% } %>
                    </div>

                    <!-- Khu vực Admin Quản Lý Ảnh Bí Mật -->
                    <div id="adminSecretsContainer" class="hidden border-t border-neutral-800 pt-6 mt-6 space-y-4">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                            <div class="space-y-1">
                                <h4 class="text-xs font-black text-amber-400 uppercase tracking-wider flex items-center gap-1.5">
                                    <span>⚙️</span> CĂN CỨ BÍ MẬT CỦA ADMIN
                                </h4>
                                <p class="text-[10px] text-gray-500">Quản lý Ảnh Bí Mật và Trạng Thái Phát Hành Game</p>
                            </div>
                        </div>

                        <!-- Cài đặt Trạng thái Game -->
                        <div class="bg-neutral-950 p-4 rounded-xl border border-neutral-850/80">
                            <h5 class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-3">Quản Lý Trạng Thái Game:</h5>
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                                <!-- Pikabeo -->
                                <div class="flex items-center justify-between bg-neutral-900 px-3 py-2 rounded-lg border border-neutral-800">
                                    <span class="text-xs font-bold text-amber-500">⚡ Pikabeo</span>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" class="sr-only peer" onchange="toggleGameSettings('pikabeo', this.checked)" <%= (gameSettings && gameSettings.pikabeo) ? 'checked' : '' %>>
                                        <div class="w-9 h-5 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-green-500"></div>
                                    </label>
                                </div>
                                <!-- Dino -->
                                <div class="flex items-center justify-between bg-neutral-900 px-3 py-2 rounded-lg border border-neutral-800">
                                    <span class="text-xs font-bold text-emerald-500">🦖 Dino Run</span>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" class="sr-only peer" onchange="toggleGameSettings('dino', this.checked)" <%= (gameSettings && gameSettings.dino) ? 'checked' : '' %>>
                                        <div class="w-9 h-5 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-green-500"></div>
                                    </label>
                                </div>
                                <!-- Dobeo -->
                                <div class="flex items-center justify-between bg-neutral-900 px-3 py-2 rounded-lg border border-neutral-800">
                                    <span class="text-xs font-bold text-blue-500">💣 Dò Beo</span>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" class="sr-only peer" onchange="toggleGameSettings('dobeo', this.checked)" <%= (gameSettings && gameSettings.dobeo) ? 'checked' : '' %>>
                                        <div class="w-9 h-5 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-green-500"></div>
                                    </label>
                                </div>
                                <!-- Caro -->
                                <div class="flex items-center justify-between bg-neutral-900 px-3 py-2 rounded-lg border border-neutral-800">
                                    <span class="text-xs font-bold text-cyan-500">⭕ Caro</span>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" class="sr-only peer" onchange="toggleGameSettings('caro', this.checked)" <%= (gameSettings && gameSettings.caro) ? 'checked' : '' %>>
                                        <div class="w-9 h-5 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-green-500"></div>
                                    </label>
                                </div>
                            </div>
                            <p class="text-[9px] text-gray-500 mt-2">*Tắt (Màu xám) = Chế độ TEST (chỉ Admin mới thấy). Bật (Màu xanh) = Public (Tất cả mọi người đều thấy).</p>
                        </div>

                        <!-- Danh sách ảnh bí mật hiện có -->
                        <div class="bg-neutral-950 p-4 rounded-xl border border-neutral-850/80">
                            <div class="flex items-center justify-between mb-3">
                                <h5 class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Kho Ảnh Bí Mật Hiện Có:</h5>
                                <div>
                                    <input type="file" id="secretImageFile" accept="image/*" class="hidden">
                                    <button onclick="document.getElementById('secretImageFile').click()" class="bg-amber-500 hover:bg-amber-400 text-black px-4 py-1.5 rounded-lg font-black text-[10px] tracking-wider transition flex items-center gap-1.5 shadow-md">
                                        <span>📤</span> TẢI ẢNH BÍ MẬT LÊN
                                    </button>
                                </div>
                            </div>
                            <div id="adminSecretsList" class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-3">
                                <!-- Render động bằng JS -->
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>
    </div>

    <!-- Container Toast -->
    <div id="toastContainer" class="fixed bottom-5 right-5 z-50 flex flex-col gap-2 max-w-sm w-full pointer-events-none"></div>

    <!-- Core Lobby Scripts -->
    <script type="module" src="/js/ui.js?v=<%= version %>"></script>
    <script type="module">
        import { showToast } from '/js/ui.js';
        window.showToast = showToast;
        
        window.toggleGameSettings = async (game_id, is_active) => {
            try {
                const res = await fetch('/api/game/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ game_id, is_active })
                });
                const data = await res.json();
                if (data.success) {
                    showToast(data.message || 'Đã lưu trạng thái!', 'success');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Có lỗi xảy ra!', 'error');
                }
            } catch (e) {
                showToast('Không thể kết nối đến server!', 'error');
            }
        };

        window.loadAdminSecretsList = async () => {
            const container = document.getElementById('adminSecretsList');
            if (!container) return;
            try {
                const res = await fetch('/api/pikabeo/secrets');
                const data = await res.json();
                if (data.success) {
                    container.innerHTML = '';
                    if (data.secrets.length === 0) {
                        container.innerHTML = `
                            <div class="col-span-full py-6 text-center text-xs text-neutral-600 font-medium">
                                Kho ảnh trống! Hệ thống đang dùng 5 ảnh Lbeo mặc định có sẵn.
                            </div>
                        `;
                        return;
                    }
                    data.secrets.forEach(sec => {
                        const card = document.createElement('div');
                        card.className = 'relative aspect-square rounded-lg border border-neutral-850 overflow-hidden group/sec shadow-inner';
                        card.innerHTML = `
                            <a href="${sec.url}" target="_blank" class="block w-full h-full cursor-zoom-in">
                                <img src="${sec.url}" class="w-full h-full object-cover hover:scale-105 transition duration-300" alt="Secret Image">
                            </a>
                            <button onclick="deleteSecretImage('${sec.name}')" class="absolute top-1.5 right-1.5 bg-red-600 hover:bg-red-500 text-white w-5 h-5 rounded-md flex items-center justify-center text-[10px] font-bold transition shadow-md opacity-0 group-hover/sec:opacity-100 z-10">
                                &times;
                            </button>
                        `;
                        container.appendChild(card);
                    });
                }
            } catch (e) {
                console.error('Lỗi khi tải kho ảnh bí mật:', e);
            }
        };

        window.deleteSecretImage = async (name) => {
            if (!confirm('Bạn có chắc chắn muốn xóa ảnh bí mật này khỏi kho lưu trữ?')) return;
            try {
                showToast('🗑️ Đang xóa ảnh bí mật...', 'info');
                const res = await fetch(`/api/pikabeo/secrets/${name}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    showToast('✅ Đã xóa ảnh bí mật thành công!', 'success');
                    loadAdminSecretsList();
                } else {
                    showToast('❌ Không thể xóa ảnh bí ẩn!', 'error');
                }
            } catch (e) {
                console.error('Lỗi khi xóa ảnh bí ẩn:', e);
                showToast('❌ Gặp lỗi kết nối khi xóa ảnh!', 'error');
            }
        };

        document.addEventListener('DOMContentLoaded', async () => {
            const adminSecretsContainer = document.getElementById('adminSecretsContainer');
            
            try {
                const res = await fetch('/api/auth/me');
                const data = await res.json();
                
                if (data.success && data.isAdmin) {
                    window.isAdmin = true;
                    if (adminSecretsContainer) {
                        adminSecretsContainer.classList.remove('hidden');
                        loadAdminSecretsList();
                    }
                } else {
                    window.isAdmin = false;
                    if (adminSecretsContainer) adminSecretsContainer.classList.add('hidden');
                }
            } catch (e) {
                console.error('Lỗi kiểm tra quyền Admin:', e);
                window.isAdmin = false;
                if (adminSecretsContainer) adminSecretsContainer.classList.add('hidden');
            }

            // Handle Secret Uploads
            const fileInput = document.getElementById('secretImageFile');
            if (fileInput) {
                fileInput.addEventListener('change', async (e) => {
                    const file = e.target.files[0];
                    if (!file) return;
                    const formData = new FormData();
                    formData.append('secretImage', file);
                    try {
                        showToast('📤 Đang tải ảnh bí mật lên...', 'info');
                        const res = await fetch('/api/pikabeo/secrets', {
                            method: 'POST',
                            body: formData
                        });
                        const data = await res.json();
                        if (data.success) {
                            showToast('✅ Đã thêm ảnh bí mật thành công vào kho lưu trữ!', 'success');
                            loadAdminSecretsList();
                        } else {
                            showToast(`❌ Lỗi: ${data.message}`, 'error');
                        }
                    } catch (err) {
                        console.error('Lỗi upload ảnh bí ẩn:', err);
                        showToast('❌ Gặp lỗi khi gửi ảnh lên máy chủ!', 'error');
                    } finally {
                        e.target.value = '';
                    }
                });
            }
        });
    </script>
</body>
</html>
