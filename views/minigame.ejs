                <div>
                    <label for="pikaInputName" class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1.5 pl-1">TÊN CAO THỦ (Tối đa 15 ký tự)</label>
                    <input type="text" id="pikaInputName" maxlength="15" autocomplete="off" placeholder="Ví dụ: LbeoDepTrai..." 
                           class="w-full bg-neutral-950 border border-neutral-850 focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-white font-bold outline-none transition shadow-inner">
                </div>

                <div class="flex gap-3 pt-2">
                    <button id="btnPikaNameCancel" class="flex-1 bg-neutral-850 hover:bg-neutral-800 text-gray-400 border border-neutral-800 py-3 rounded-xl font-black text-xs tracking-wider transition">
                        HỦY BỎ
                    </button>
                    <button id="btnPikaNameSubmit" class="flex-1 bg-amber-500 hover:bg-amber-400 text-black py-3 rounded-xl font-black text-xs tracking-wider transition shadow-lg shadow-amber-500/20">
                        BẮT ĐẦU CHƠI 🚀
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Lớp phủ Bảng Xếp Hạng Glassmorphism cho Dino (Full Screen) -->
    <div id="dinoLeaderboardOverlay" class="fixed inset-0 bg-black/90 backdrop-blur-md z-50 hidden flex flex-col items-center justify-center p-4">
        <div class="w-full max-w-4xl bg-neutral-900/95 border border-neutral-700/80 rounded-3xl p-6 shadow-2xl space-y-5 flex flex-col justify-between transform scale-95 transition-all duration-300">
            <div class="space-y-2 text-center select-none">
                <h4 class="text-2xl md:text-3xl font-black text-amber-500 uppercase tracking-widest flex items-center justify-center gap-2">
                    <span class="text-4xl animate-bounce">🏆</span> BẢNG XẾP HẠNG
                </h4>
                <p class="text-sm md:text-base text-gray-400">Những quái xế lạng lách đỉnh cao nhất!</p>
            </div>

            <div class="bg-neutral-950/80 rounded-2xl border border-neutral-800 overflow-hidden shadow-xl w-full min-h-[400px] max-h-[65vh] overflow-y-auto custom-scrollbar my-4">
                <table class="w-full text-left border-collapse text-base md:text-lg">
                    <thead>
                        <tr class="border-b border-neutral-800 bg-neutral-900 text-sm md:text-base uppercase font-black text-indigo-400 select-none">
                            <th class="py-5 px-6 text-center w-20">Hạng</th>
                            <th class="py-5 px-6">Quái Xế</th>
                            <th class="py-5 px-8 text-right">Điểm Kỷ Lục</th>
                        </tr>
                    </thead>
                    <tbody id="dinoLeaderboardList" class="divide-y divide-neutral-800 font-bold text-gray-200">
                        <tr>
                            <td colspan="3" class="py-12 text-center text-neutral-500 font-medium select-none text-lg">
                                Đang tải bảng xếp hạng...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="flex justify-center pt-2">
                <button id="btnDinoCloseLeaderboard" class="bg-red-950/40 hover:bg-red-900/60 text-red-400 font-black text-base md:text-lg px-12 py-4 rounded-xl border border-red-900/50 transition-all tracking-wider flex items-center gap-2 shadow-md hover:shadow-red-900/20">
                    Đóng Xếp Hạng ❌
                </button>
            </div>
        </div>
    </div>

    <!-- Modal nhập tên trước khi bắt đầu chơi Dino -->
    <div id="dinoNameModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-md hidden transition-all duration-300">
        <div class="bg-neutral-900 border border-neutral-800 p-6 md:p-8 rounded-3xl max-w-sm w-full mx-4 shadow-2xl space-y-6 relative overflow-hidden transform scale-95 transition-all duration-300">
            <div class="absolute -top-12 -left-12 w-24 h-24 bg-emerald-500/10 rounded-full filter blur-xl pointer-events-none"></div>
            <div class="absolute -bottom-12 -right-12 w-24 h-24 bg-cyan-500/10 rounded-full filter blur-xl pointer-events-none"></div>
            
            <div class="text-center space-y-2 relative">
                <span class="text-4xl block animate-bounce">🦖🏎️</span>
                <h3 class="text-lg font-black text-white uppercase tracking-wider">ĐĂNG KÝ DANH TÁNH</h3>
                <p class="text-xs text-neutral-400 leading-relaxed">
                    Nhập tên của bạn để bắt đầu cuộc đua giành vị trí Top 1 trên Bảng Xếp Hạng!
                </p>
            </div>

            <div class="space-y-4 relative">
                <div>
                    <label for="dinoInputName" class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1.5 pl-1">TÊN QUÁI XẾ (Tối đa 15 ký tự)</label>
                    <input type="text" id="dinoInputName" maxlength="15" autocomplete="off" placeholder="Ví dụ: BoyRacing..." 
                           class="w-full bg-neutral-950 border border-neutral-850 focus:border-emerald-500/50 rounded-xl px-4 py-3 text-sm text-white font-bold outline-none transition shadow-inner">
                </div>

                <div class="flex gap-3 pt-2">
                    <button id="btnDinoNameCancel" class="flex-1 bg-neutral-850 hover:bg-neutral-800 text-gray-400 border border-neutral-800 py-3 rounded-xl font-black text-xs tracking-wider transition">
                        HỦY BỎ
                    </button>
                    <button id="btnDinoNameSubmit" class="flex-1 bg-emerald-500 hover:bg-emerald-400 text-black py-3 rounded-xl font-black text-xs tracking-wider transition shadow-lg shadow-emerald-500/20">
                        BẮT ĐẦU ĐUA 🚀
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Dedicated Page Setup -->
    <script type="module">
        import { showToast } from '/js/ui.js';
        window.showToast = showToast;
        
        document.addEventListener('DOMContentLoaded', async () => {
            const adminSecretsContainer = document.getElementById('adminSecretsContainer');
            
            try {
                const res = await fetch('/api/auth/me');
                const data = await res.json();
                
                if (data.success && data.isAdmin) {
                    window.isAdmin = true;
                    if (adminSecretsContainer) {
                        adminSecretsContainer.classList.remove('hidden');
                        if (window.pikaGame) {
                            window.pikaGame.loadAdminSecretsList();
                        }
                    }
                } else {
                    window.isAdmin = false;
                    if (adminSecretsContainer) adminSecretsContainer.classList.add('hidden');
                }
            } catch (e) {
                console.error('Lỗi kiểm tra quyền Admin:', e);
                window.isAdmin = false;
                if (adminSecretsContainer) adminSecretsContainer.classList.add('hidden');
            }

            // Tải bảng xếp hạng lúc khởi động trang
            if (window.pikaGame) {
                window.pikaGame.loadLeaderboard();
            }
        });
    </script>
</body>

</html>
